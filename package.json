{
  "name": "llm-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nx run-many --targets=dev --parallel=1",
    "dev:api": "nx run api:dev",
    "dev:worker": "nx run worker:dev",
    "dev:admin": "nx run admin:dev",
    "dev:frontend": "nx run frontend:dev",
    "build": "nx run-many --targets=build",
    "build:api": "nx run api:build",
    "build:worker": "nx run worker:build",
    "test": "nx run-many --targets=test",
    "lint": "nx run-many --targets=lint",
    "prisma:generate": "nx run api:prisma:generate",
    "prisma:migrate": "nx run api:prisma:migrate"
  },
  "nx": {
    "includedScripts": []
  },
  "devDependencies": {
    "nx": "^20.0.0",
    "@nx/js": "^20.0.0",
    "@nx/vite": "^20.0.0",
    "@nx/cypress": "^20.0.0",
    "@nx/playwright": "^20.0.0"
  }
}